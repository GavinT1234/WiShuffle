# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/wishuffle"

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# JWT Secret (for authentication - add this later)
JWT_SECRET=your_jwt_secret_key_here

# AWS Configuration (optional, for future S3 integration)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Other configurations
LOG_LEVEL=debug
